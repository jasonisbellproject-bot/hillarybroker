const { createClient } = require('@supabase/supabase-js')

// Load environment variables
require('dotenv').config({ path: '.env.local' })

const supabaseUrl = process.env.NEXT_PUBLIC_SUPABASE_URL
const supabaseServiceKey = process.env.SUPABASE_SERVICE_ROLE_KEY

if (!supabaseUrl || !supabaseServiceKey) {
  console.error('❌ Missing environment variables')
  console.error('Make sure you have NEXT_PUBLIC_SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY in your .env.local file')
  process.exit(1)
}

const supabase = createClient(supabaseUrl, supabaseServiceKey)

async function createTestUser() {
  try {
    console.log('🔧 Creating test user...')

    // Create user in Supabase Auth
    const { data: authData, error: authError } = await supabase.auth.admin.createUser({
      email: 'test2@example.com',
      password: 'password123',
      email_confirm: true,
    })

    if (authError) {
      console.error('❌ Auth error:', authError)
      return
    }

    console.log('✅ User created in Auth:', authData.user.email)

    // Create user profile in database
    const { data: profileData, error: profileError } = await supabase
      .from('users')
      .insert({
        id: authData.user.id,
        email: 'test2@example.com',
        first_name: 'Test',
        last_name: 'User',
        kyc_verified: false,
        two_factor_enabled: false,
      })
      .select()

    if (profileError) {
      console.error('❌ Profile error:', profileError)
      return
    }

    console.log('✅ User profile created:', profileData[0])

    // Add some test data
    console.log('🔧 Adding test data...')

    // Add test deposits
    const { error: depositError } = await supabase
      .from('deposits')
      .insert([
        {
          user_id: authData.user.id,
          amount: 1500,
          currency: 'USD',
          payment_method: 'Bitcoin',
          status: 'completed',
          transaction_hash: '0x1234...5678',
        },
        {
          user_id: authData.user.id,
          amount: 2500,
          currency: 'USD',
          payment_method: 'Ethereum',
          status: 'completed',
          transaction_hash: '0x8765...4321',
        }
      ])

    if (depositError) {
      console.error('❌ Deposit error:', depositError)
    } else {
      console.log('✅ Test deposits added')
    }

    // Add test investments
    const { error: investmentError } = await supabase
      .from('investments')
      .insert([
        {
          user_id: authData.user.id,
          plan_id: 1,
          amount: 1000,
          daily_return: 2.5,
          total_return: 75,
          status: 'active',
        }
      ])

    if (investmentError) {
      console.error('❌ Investment error:', investmentError)
    } else {
      console.log('✅ Test investments added')
    }

    console.log('🎉 Test user created successfully!')
    console.log('📧 Email: test2@example.com')
    console.log('🔑 Password: password123')
    console.log('🔗 Login at: http://localhost:3000/login')

  } catch (error) {
    console.error('❌ Error creating test user:', error)
  }
}

createTestUser() 